APP_NAME=AnyLang
APP_ENV=local
DEBUG=true
API_V1_PREFIX=/api/v1

# Security — change in production (min 48 chars when APP_ENV=production)
SECRET_KEY=change-me-to-a-long-random-string-at-least-64-chars
# Separate admin JWT key (recommended; required distinct in production if set)
ADMIN_SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=60

# Database (docker-compose maps host 15432 → container 5432)
DATABASE_URL=postgresql+asyncpg://anylang:anylang@localhost:15432/anylang

# Redis (docker-compose maps host 16379 → container 6379)
REDIS_URL=redis://localhost:16379/0

# S3 / MinIO (local) — prod: Cloudflare R2
S3_ENDPOINT_URL=http://localhost:19000
S3_ACCESS_KEY=anylang
S3_SECRET_KEY=anylangsecret
S3_BUCKET=anylang
S3_REGION=auto
S3_PUBLIC_BASE_URL=http://localhost:19000/anylang

# Email (local Mailpit SMTP)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=AnyLang <noreply@anylang.local>
SMTP_TLS=false
# Local only: allow OTP in API when SMTP is down. Must be false in production.
SMTP_FAIL_OPEN=true
ALLOW_OTP_IN_RESPONSE=true

# Google Sign-In (comma-separated client IDs) — required in production
GOOGLE_CLIENT_IDS=

# AI providers (mock OK in local; required real keys in production)
DEEPL_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
TRANSLATION_PROVIDER=mock

# Payments — mock in local; set stripe + keys for production
PAYMENT_PROVIDER=mock
ALLOW_MOCK_PAYMENTS=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:3000/billing/success
STRIPE_CANCEL_URL=http://localhost:3000/billing/cancel

# Admin bootstrap (local seed). Never use default password in production.
ADMIN_EMAIL=admin@anylang.com
ADMIN_PASSWORD=Admin123!
ADMIN_SEED_IN_PRODUCTION=false

# CORS (Flutter web / admin) — explicit list required in production
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Trusted hosts (required in production), e.g. api.anylang.com,localhost
TRUSTED_HOSTS=

# Sentry (optional)
SENTRY_DSN=
