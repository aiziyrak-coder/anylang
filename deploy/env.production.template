# AnyLang production — copy to deploy/.env and fill secrets before first deploy.
APP_NAME=AnyLang
APP_ENV=production
DEBUG=false
API_V1_PREFIX=/api/v1

SECRET_KEY=REPLACE_WITH_openssl_rand_base64_48
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=60

POSTGRES_PASSWORD=REPLACE_STRONG_PG_PASSWORD

DATABASE_URL=postgresql+asyncpg://anylang:REPLACE_STRONG_PG_PASSWORD@postgres:5432/anylang
REDIS_URL=redis://redis:6379/0

S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=anylang_prod
S3_SECRET_KEY=REPLACE_STRONG_S3_SECRET
S3_BUCKET=anylang
S3_REGION=auto
S3_PUBLIC_BASE_URL=https://anylang.uz/media

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=AnyLang <noreply@anylang.uz>
SMTP_TLS=true

GOOGLE_CLIENT_IDS=
TRANSLATION_PROVIDER=openai
ALLOW_MOCK_TRANSLATION=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
DEEPL_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

PAYMENT_PROVIDER=mock
ALLOW_MOCK_PAYMENTS=true
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=https://anylang.uz/billing/success
STRIPE_CANCEL_URL=https://anylang.uz/billing/cancel

ADMIN_EMAIL=admin@anylang.com
ADMIN_PASSWORD=REPLACE_STRONG_ADMIN_PASSWORD
ADMIN_SEED_IN_PRODUCTION=true

CORS_ORIGINS=https://anylang.uz,https://www.anylang.uz
TRUSTED_HOSTS=anylang.uz,www.anylang.uz,127.0.0.1,localhost

SENTRY_DSN=
